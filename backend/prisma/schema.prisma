generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PARTICIPANT
}

enum MatchStage {
  GROUP_STAGE
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  FINISHED
  CANCELLED
}

enum PaymentProvider {
  ASAAS
  MERCADO_PAGO
  MOCK
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  CANCELLED
}

model User {
  id                 String       @id @default(uuid()) @db.Uuid
  name               String       @db.VarChar(150)
  nickname           String?      @db.VarChar(80)
  email              String       @unique @db.VarChar(150)
  passwordHash       String       @map("password_hash") @db.VarChar(255)
  avatarUrl          String?      @map("avatar_url") @db.Text
  role               UserRole     @default(PARTICIPANT)
  acceptedInviteCode String?      @map("accepted_invite_code") @db.VarChar(60)
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  predictions        Prediction[]
  bonusPredictions   BonusPrediction[]
  groupPredictions   GroupStandingPrediction[]

  @@map("users")
}

model InviteCode {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(60)
  label     String   @db.VarChar(120)
  isActive  Boolean  @default(true) @map("is_active")
  maxUses   Int?     @map("max_uses")
  usedCount Int      @default(0) @map("used_count")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("invite_codes")
}

model Payment {
  id                    String          @id @default(uuid()) @db.Uuid
  provider              PaymentProvider @default(MOCK)
  status                PaymentStatus   @default(PENDING)
  amountCents           Int             @map("amount_cents")
  currency              String          @default("BRL") @db.VarChar(3)
  name                  String          @db.VarChar(150)
  nickname              String?         @db.VarChar(80)
  email                 String          @db.VarChar(150)
  document              String?         @db.VarChar(20)
  passwordHash          String          @map("password_hash") @db.VarChar(255)
  accessCode            String          @unique @map("access_code") @db.VarChar(60)
  providerCustomerId    String?         @map("provider_customer_id") @db.VarChar(120)
  providerPaymentId     String?         @unique @map("provider_payment_id") @db.VarChar(120)
  providerStatus        String?         @map("provider_status") @db.VarChar(80)
  providerStatusDetail  String?         @map("provider_status_detail") @db.VarChar(120)
  qrCode                String?         @map("qr_code") @db.Text
  qrCodeBase64          String?         @map("qr_code_base64") @db.Text
  ticketUrl             String?         @map("ticket_url") @db.Text
  rawProviderResponse   Json?           @map("raw_provider_response")
  paidAt                DateTime?       @map("paid_at")
  expiresAt             DateTime        @map("expires_at")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  @@index([email])
  @@index([status])
  @@map("payments")
}

model Match {
  id              String       @id @default(uuid()) @db.Uuid
  matchNumber     Int          @unique @map("match_number")
  homeTeam        String       @map("home_team") @db.VarChar(100)
  awayTeam        String       @map("away_team") @db.VarChar(100)
  groupCode       String?      @map("group_code") @db.VarChar(2)
  stage           MatchStage
  venue           String       @db.VarChar(150)
  city            String       @db.VarChar(100)
  matchDateUtc    DateTime     @map("match_date_utc")
  lockAtUtc       DateTime     @map("lock_at_utc")
  homeScore       Int?         @map("home_score")
  awayScore       Int?         @map("away_score")
  status          MatchStatus  @default(SCHEDULED)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  predictions     Prediction[]

  @@index([stage, groupCode])
  @@index([matchDateUtc])
  @@map("matches")
}

model Prediction {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  matchId             String   @map("match_id") @db.Uuid
  homeScorePrediction Int      @map("home_score_prediction")
  awayScorePrediction Int      @map("away_score_prediction")
  points              Int      @default(0)
  isExactScore        Boolean  @default(false) @map("is_exact_score")
  isCorrectResult     Boolean  @default(false) @map("is_correct_result")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match               Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([matchId])
  @@index([userId])
  @@map("predictions")
}

model BonusQuestion {
  id            String            @id @default(uuid()) @db.Uuid
  title         String            @unique @db.VarChar(120)
  description   String            @db.VarChar(255)
  points        Int               @default(10)
  lockAtUtc     DateTime          @map("lock_at_utc")
  correctAnswer String?           @map("correct_answer") @db.VarChar(120)
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  predictions   BonusPrediction[]

  @@index([lockAtUtc])
  @@map("bonus_questions")
}

model BonusPrediction {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  questionId  String        @map("question_id") @db.Uuid
  answer      String        @db.VarChar(120)
  points      Int           @default(0)
  isCorrect   Boolean       @default(false) @map("is_correct")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  question    BonusQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId])
  @@index([userId])
  @@map("bonus_predictions")
}

model BonusControl {
  key       String   @id @db.VarChar(80)
  lockAtUtc DateTime @map("lock_at_utc")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("bonus_controls")
}

model GroupStandingPrediction {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  groupCode        String   @map("group_code") @db.VarChar(2)
  firstTeam        String   @map("first_team") @db.VarChar(100)
  secondTeam       String   @map("second_team") @db.VarChar(100)
  thirdTeam        String   @map("third_team") @db.VarChar(100)
  fourthTeam       String   @map("fourth_team") @db.VarChar(100)
  points           Int      @default(0)
  correctPositions Int      @default(0) @map("correct_positions")
  isPerfect        Boolean  @default(false) @map("is_perfect")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, groupCode])
  @@index([groupCode])
  @@index([userId])
  @@map("group_standing_predictions")
}

model GroupStandingResult {
  id         String   @id @default(uuid()) @db.Uuid
  groupCode  String   @unique @map("group_code") @db.VarChar(2)
  firstTeam  String   @map("first_team") @db.VarChar(100)
  secondTeam String   @map("second_team") @db.VarChar(100)
  thirdTeam  String   @map("third_team") @db.VarChar(100)
  fourthTeam String   @map("fourth_team") @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("group_standing_results")
}
